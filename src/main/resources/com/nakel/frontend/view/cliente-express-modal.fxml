<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane hgap="10.0" vgap="10.0" stylesheets="@../../../../css/nakel.css" styleClass="mostrador-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nakel.frontend.controller.ClienteExpressController">    <padding>
        <Insets bottom="10.0" left="10.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="DNI/CUIT:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtDni" promptText="Ej: 20123456789" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtNombre" promptText="Nombre y Apellido" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
    </children>
</GridPane>
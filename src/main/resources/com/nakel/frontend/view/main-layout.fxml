<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<?import javafx.scene.layout.StackPane?>

<BorderPane
        prefHeight="700.0"
        prefWidth="1000.0"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.nakel.frontend.controller.MainController">

    <left>

        <VBox prefWidth="260.0"
              spacing="10"
              styleClass="sidebar"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets top="25" right="15" bottom="20" left="15"/>
            </padding>

            <!-- LOGO -->

            <HBox alignment="CENTER_LEFT"
                  spacing="12">

                <Label text="NAKEL"
                       styleClass="logo"/>

                <Label text="|"
                       styleClass="logo-separator"/>

                <ImageView fitHeight="60" preserveRatio="true">
                    <image>
                        <Image url="@../../../../images/Logoo.png"/>
                    </image>
                </ImageView>

                <VBox.margin>
                    <Insets bottom="25"/>
                </VBox.margin>

            </HBox>

            <!-- MOSTRADOR -->

            <Button text="🛒 Mostrador (Nueva Venta)"
                    maxWidth="999"
                    styleClass="primary-button"
                    onAction="#mostrarMostrador"/>

            <!-- GESTION -->

            <Label text="GESTIÓN"
                   styleClass="section-title">

                <VBox.margin>
                    <Insets top="25" bottom="5"/>
                </VBox.margin>

            </Label>

            <Button text="📦 Catálogo (Artículos)"
                    maxWidth="999"
                    styleClass="menu-button"/>

            <Button text="👥 Clientes"
                    maxWidth="999"
                    styleClass="menu-button"
                    onAction="#mostrarClientes"/>

            <Button text="🚚 Proveedores"
                    maxWidth="999"
                    styleClass="menu-button"
                    onAction="#mostrarProveedores"/>

            <!-- VENTAS -->

            <Label text="VENTAS"
                   styleClass="section-title">

                <VBox.margin>
                    <Insets top="20" bottom="5"/>
                </VBox.margin>

            </Label>

            <!--<Button text="🛍 Ventas"
                    maxWidth="999"
                    styleClass="menu-button"
                    onAction="#mostrarPuntoDeVenta"/> -->

            <Button text="🧾 Historial de Ventas"
                    maxWidth="999"
                    styleClass="menu-button"
                    onAction="#mostrarHistorialVentas"/>

            <Button text="💰 Historial de Cajas"
                    maxWidth="999"
                    styleClass="menu-button"/>

            <!-- HERRAMIENTAS -->

            <Label text="HERRAMIENTAS"
                   styleClass="section-title">

                <VBox.margin>
                    <Insets top="20" bottom="5"/>
                </VBox.margin>

            </Label>

            <Button text="🧮 Gestión de Insumos"
                    maxWidth="999"
                    styleClass="menu-button"
                    onAction="#mostrarInsumos"/>

            <Button text="🧮 Calcular Producción"
                    maxWidth="999"
                    styleClass="menu-button"
                    onAction="#mostrarCalculadora"/>

            <!-- REPORTES -->

            <Label text="REPORTES"
                   styleClass="section-title">

                <VBox.margin>
                    <Insets top="20" bottom="5"/>
                </VBox.margin>

            </Label>

            <Button text="📊 Estadísticas"
                    maxWidth="999"
                    styleClass="menu-button"/>

            <VBox VBox.vgrow="ALWAYS"/>

            <!-- CONFIGURACION -->

            <Button text="⚙ Configuración"
                    maxWidth="999"
                    styleClass="config-button"/>

            <!-- CERRAR CAJA -->

            <Button text="🔒 Cerrar Caja"
                    maxWidth="999"
                    styleClass="danger-button"/>

        </VBox>

    </left>

    <center>
        <!-- Este StackPane vacío es donde vamos a meter todas las otras vistas -->
        <StackPane fx:id="areaContenido" styleClass="content-area"/>
    </center>

</BorderPane>
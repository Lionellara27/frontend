<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="250.0" prefWidth="350.0" style="-fx-background-color: #F4F6F8; -fx-border-color: #CCCCCC; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nakel.frontend.controller.NuevaCategoriaController">
    <children>
        <VBox alignment="CENTER_LEFT" layoutX="25.0" layoutY="20.0" prefHeight="210.0" prefWidth="300.0" spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="25.0" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="Nueva Categoría">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Nombre (Ej: Cueros, Hilos, Cierres)" />
                        <TextField fx:id="txtNombreCategoria" prefHeight="30.0" promptText="Ingrese el nombre..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="¿Cómo se mide o cobra esta categoría?" />
                        <ComboBox fx:id="cmbTipoMedicion" prefHeight="30.0" prefWidth="300.0" promptText="Seleccione medición..." />
                    </children>
                </VBox>
                <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="200.0" spacing="10.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#cancelar" prefHeight="30.0" prefWidth="90.0" style="-fx-background-color: #E0E0E0;" text="Cancelar" />
                        <Button mnemonicParsing="false" onAction="#guardarCategoria" prefHeight="30.0" prefWidth="90.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar" />
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
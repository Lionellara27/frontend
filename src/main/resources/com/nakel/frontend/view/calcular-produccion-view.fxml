<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="modulo-container"
      stylesheets="@../../../../css/nakel.css"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nakel.frontend.controller.CalculadoraController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- ENCABEZADO -->
    <HBox alignment="CENTER_LEFT">
        <Label text="🧮 Calculadora de Producción" styleClass="titulo-modulo"/>
    </HBox>

    <!-- BLOQUE 1: PANEL INTELIGENTE DE INGRESO -->
    <VBox spacing="15" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Categoría:"/>
            <ComboBox fx:id="cmbCategoriaItem" promptText="Tela / Accesorio / Labor" prefWidth="150" styleClass="text-field"/>

            <Label text="Insumo específico:"/>
            <ComboBox fx:id="cmbInsumo" promptText="Seleccionar..." prefWidth="250" styleClass="text-field"/>
        </HBox>

        <Separator/>

        <!-- Campos de dimensiones y cantidades (El sistema ocultará los que no sirvan según la categoría) -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <!-- Para Telas / Cueros -->
            <Label text="Medidas del Recorte:"/>
            <TextField fx:id="txtAncho" promptText="Ancho (cm)" prefWidth="100" styleClass="text-field"/>
            <Label text="X"/>
            <TextField fx:id="txtAlto" promptText="Alto (cm)" prefWidth="100" styleClass="text-field"/>

            <!-- Para Accesorios / Horas -->
            <Label text="  |  O Cantidad / Horas:"/>
            <TextField fx:id="txtCantidad" promptText="Ej: 2" prefWidth="80" styleClass="text-field"/>

            <Pane HBox.hgrow="ALWAYS" /> <!-- Espaciador para tirar el botón a la derecha -->

            <Button text="➕ Agregar al Presupuesto" styleClass="btn-secundario" onAction="#agregarInsumoLista"/>
        </HBox>
    </VBox>

    <!-- BLOQUE 2: EL TICKET (Acá se van apilando los cálculos) -->
    <TableView fx:id="tablaPresupuesto" VBox.vgrow="ALWAYS" styleClass="tabla-estandar">
        <columns>
            <TableColumn text="Descripción" prefWidth="200"/>
            <TableColumn text="Categoría" prefWidth="100"/>
            <TableColumn text="Detalle (Recorte/Cant)" prefWidth="150"/>
            <TableColumn text="Costo Base" prefWidth="100"/>
            <TableColumn text="Subtotal Calculado" prefWidth="140"/>
            <TableColumn text="Acciones" prefWidth="80"/>
        </columns>
    </TableView>

    <!-- BLOQUE 3: TOTALES Y RENTABILIDAD -->
    <HBox alignment="CENTER_RIGHT" spacing="25" style="-fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">

        <GridPane vgap="12" hgap="15">
            <Label text="Costo Total de Producción:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblCostoTotal" text="/$ 0.00" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-weight: bold;"/>

            <!-- Tu idea de los impuestos aplicada visualmente -->
            <Label text="Margen de Ganancia (%):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <TextField fx:id="txtMargen" promptText="Ej: 50" prefWidth="70" styleClass="text-field"/>
                <Label text="(Mínimo sugerido: 21% por impuestos)" style="-fx-text-fill: #e65100; -fx-font-size: 11px;"/>
            </HBox>

            <Label text="Precio de Venta Sugerido:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
            <Label fx:id="lblPrecioFinal" text="/$ 0.00" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
        </GridPane>

        <Separator orientation="VERTICAL"/>

        <Button text="💾 Guardar Presupuesto" styleClass="btn-primario" onAction="#guardarPresupuesto" prefHeight="50"/>

    </HBox>

</VBox>
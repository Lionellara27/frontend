<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" styleClass="modulo-container"
      stylesheets="@../../../../css/nakel.css"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nakel.frontend.controller.ProveedorController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="🏭 Directorio de Proveedores" styleClass="titulo-modulo"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="txtBuscarProveedor" promptText="Buscar por nombre, empresa o rubro..." HBox.hgrow="ALWAYS" styleClass="input-busqueda"/>
        <Button text="🔍 Buscar" styleClass="btn-secundario" onAction="#buscarProveedor"/>

        <Button text="➕ Nuevo Proveedor" styleClass="btn-primario" onAction="#abrirModalNuevoProveedor"/>
    </HBox>

    <TableView fx:id="tablaProveedores" VBox.vgrow="ALWAYS" styleClass="tabla-estandar">
        <columns>
            <TableColumn fx:id="colRazonSocial" text="Razón Social / Empresa" prefWidth="200"/>
            <TableColumn fx:id="colNombreContacto" text="Nombre Contacto" prefWidth="150"/>
            <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="120"/>
            <TableColumn fx:id="colRubro" text="Rubro (Ej: Cueros)" prefWidth="120"/>
            <TableColumn fx:id="colSaldo" text="Saldo Cta. Cte." prefWidth="120"/>
            <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="150"/>
        </columns>
    </TableView>

</VBox>
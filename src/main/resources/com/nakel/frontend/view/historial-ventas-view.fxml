<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" styleClass="modulo-container"
      stylesheets="@../../../../css/nakel.css"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nakel.frontend.controller.HistorialVentasController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="🧾 Historial de Comprobantes y Ventas" styleClass="titulo-modulo"/>
        <Pane HBox.hgrow="ALWAYS" />
        <Button text="🛒 NUEVA VENTA (POS)" styleClass="btn-primario" onAction="#abrirPuntoDeVenta"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <ComboBox fx:id="cmbMes" promptText="Mes actual" styleClass="text-field"/>
        <TextField fx:id="txtBuscarVenta" promptText="Buscar por Nro, Cliente o DNI..." HBox.hgrow="ALWAYS" styleClass="input-busqueda"/>
        <Button text="🔍 Filtrar" styleClass="btn-secundario"/>
    </HBox>

    <TableView fx:id="tablaVentas" VBox.vgrow="ALWAYS" styleClass="tabla-estandar">
        <columns>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="150"/>
            <TableColumn fx:id="colNro" text="Punto Venta - Nro" prefWidth="130"/>
            <TableColumn fx:id="colCliente" text="Cliente" prefWidth="200"/>
            <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
            <TableColumn fx:id="colEstado" text="Estado AFIP" prefWidth="120"/>
            <TableColumn fx:id="colAcciones" text="Acciones (Ver/Imprimir/Mail)" prefWidth="200"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 10 0 0 0;">
        <Label text="Total Facturado en pantalla:" style="-fx-font-size: 14px;"/>
        <Label fx:id="lblTotalFacturado" text="/$ 0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
    </HBox>

</VBox>
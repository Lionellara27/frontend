<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="450.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nakel.frontend.controller.TabDivisasController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Cotización de Referencia (USD)" />
                        <CheckBox fx:id="chkActualizacionAutomatica" mnemonicParsing="false" onAction="#toggleModoAutomatico" text="🔄 Actualizar automáticamente" />
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Label text="Cotización Actual ARS:" />
                                <TextField fx:id="txtCotizacionDolar" prefWidth="120.0" promptText="Ej: 1250" />
                                <Button fx:id="btnGuardarCotizacion" mnemonicParsing="false" onAction="#guardarCotizacion" text="💾 Guardar Cambios" />
                            </children>
                        </HBox>
                        <Label style="-fx-text-fill: gray; -fx-font-size: 11px;" text="* Esta cotización se usará para alertar desfasajes y para el botón de conversión a USD en el mostrador." />
                    </children>
                </VBox>

                <VBox spacing="10.0">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="⚡ Actualización Masiva de Precios" />
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="180.0" minWidth="10.0" prefWidth="120.0" />
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="250.0" minWidth="10.0" prefWidth="200.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label text="Categoría:" />
                                <ComboBox fx:id="cmbCategoriaAumento" prefWidth="200.0" promptText="Todas las categorías" GridPane.columnIndex="1" />
                                <Label text="Porcentaje (%):" GridPane.rowIndex="1" />
                                <TextField fx:id="txtPorcentajeAumento" maxWidth="100.0" promptText="Ej: 15" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            </children>
                        </GridPane>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Button fx:id="btnAplicarAumento" mnemonicParsing="false" onAction="#aplicarAumentoMasivo" styleClass="btn-eliminar" style="-fx-background-color: #e67e22;" text="🚀 Aplicar Aumento Masivo" textFill="WHITE" />
                                <Button fx:id="btnSincronizarDolar" mnemonicParsing="false" onAction="#sincronizarPreciosConDolar" text="🔄 Sincronizar ARS según Dólar" />
                            </children>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="450.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nakel.frontend.controller.TabParametrosController">
    <children>
        <HBox spacing="30.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Categorías de Artículos" />
                        <ListView fx:id="listCategorias" prefHeight="300.0" VBox.vgrow="ALWAYS" />
                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="txtNuevaCategoria" promptText="Nueva categoría..." HBox.hgrow="ALWAYS" />

                                <TextField fx:id="txtNuevoPrefijo" promptText="Prefijo (Ej: 1111)" prefWidth="120.0" />

                                <Button mnemonicParsing="false" onAction="#agregarCategoria" text="➕" />
                                <Button mnemonicParsing="false" onAction="#eliminarCategoria" styleClass="btn-eliminar" text="🗑️" textFill="WHITE" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Materiales / Telas" />
                        <ListView fx:id="listMateriales" prefHeight="300.0" VBox.vgrow="ALWAYS" />
                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="txtNuevoMaterial" promptText="Nuevo material..." HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#agregarMaterial" text="➕" />
                                <Button mnemonicParsing="false" onAction="#eliminarMaterial" styleClass="btn-eliminar" text="🗑️" textFill="WHITE" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
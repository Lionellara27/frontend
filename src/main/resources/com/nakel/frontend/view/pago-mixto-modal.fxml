<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" stylesheets="@../../../../css/nakel.css" styleClass="mostrador-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nakel.frontend.controller.PagoMixtoController">
    <children>
        <Label fx:id="lblTotal" text="Total de la Venta: $ 0.00" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
        <Label fx:id="lblFalta" text="Falta Cobrar: $ 0.00" style="-fx-font-size: 18px; -fx-text-fill: #d32f2f; -fx-font-weight: bold;" />

        <HBox fx:id="cajaAgregar" spacing="10.0" alignment="CENTER_LEFT">
            <children>
                <TextField fx:id="txtMonto" promptText="Ej: 20000" styleClass="text-field" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="cmbMetodo" promptText="Método" styleClass="combo-pago" prefWidth="150.0" />
                <Button fx:id="btnAgregar" text="➕ Agregar" styleClass="btn-secundario" onAction="#agregarPago" />
            </children>
        </HBox>

        <ListView fx:id="listaPagos" prefHeight="120.0" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
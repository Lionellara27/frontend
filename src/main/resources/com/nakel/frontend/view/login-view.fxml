<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nakel.frontend.controller.LoginController"
      alignment="CENTER"
      spacing="15"
      prefWidth="600"
      prefHeight="400"
      styleClass="login-root">

    <!-- Logo Tipográfico -->
    <Label text="NAKEL"
           styleClass="login-logo"/>

    <!-- Eslogan -->
    <Label text="Cuero &amp; Tradición Patagónica"
           styleClass="login-subtitle"/>

    <!-- Campo de Usuario -->
    <TextField fx:id="txtUsuario"
               promptText="Usuario"
               maxWidth="280"
               styleClass="login-field"/>

    <!-- Campo de Contraseña -->
    <PasswordField fx:id="txtPassword"
                   promptText="Contraseña"
                   maxWidth="280"
                   styleClass="login-field"/>

    <!-- Botón de Ingreso -->
    <Button text="Ingresar al Sistema"
            onAction="#onIngresarClick"
            styleClass="primary-button"/>

</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="modulo-container"
      stylesheets="@../../../../css/nakel.css"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nakel.frontend.controller.NuevoProveedorController"
      prefWidth="450">

    <padding>
        <Insets top="20" right="25" bottom="20" left="25"/>
    </padding>

    <Label text="➕ Alta de Nuevo Proveedor" styleClass="titulo-modulo"/>

    <GridPane vgap="15" hgap="10">

        <Label text="Empresa / Marca:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtEmpresa" promptText="Ej: Curtiembre San José" GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" styleClass="text-field"/>

        <Label text="Nombre Contacto:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtContacto" promptText="Ej: Carlos (Vendedor)" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="text-field"/>

        <Label text="Rubro:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cmbRubro" promptText="Seleccionar..." GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity" styleClass="text-field"/>

        <Label text="Teléfono / WhatsApp:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTelefono" promptText="Ej: 2920-123456" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="text-field"/>

        <Label text="Email:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtEmail" promptText="ventas@proveedor.com" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="text-field"/>

        <Label text="Saldo ($):" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="txtSaldo" promptText="Ej: 0.00 o -5000" GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="text-field"/>

    </GridPane>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Cancelar" styleClass="btn-secundario" onAction="#cerrarModal"/>
        <Button text="💾 Guardar" styleClass="btn-primario" onAction="#guardarProveedor"/>
    </HBox>

</VBox>
                        <VBox alignment="CENTER" prefHeight="120.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Catálogo Activo" textFill="#7f8c8d">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Label fx:id="lblTotalProductos" text="0" textFill="#2980b9">

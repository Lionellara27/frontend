                        <VBox alignment="CENTER" prefHeight="120.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Ventas 7 Días" textFill="#7f8c8d">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Label fx:id="lblVentasSemana" text="/$ 0.00" textFill="#2c3e50">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                </Label>
                                <Label fx:id="lblCantidadSemana" text="0 ventas" textFill="#95a5a6" />
